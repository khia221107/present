    <!-- Scripts for Gemini API Integration -->
    <script>
        const apiKey = ""; // API Key is injected by the execution environment

        // Core API Call function with Exponential Backoff
        async function fetchGeminiAPI(prompt, retries = 5) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: prompt }] }]
            };

            for (let i = 0; i < retries; i++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    
                    if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
                    
                    const data = await response.json();
                    if (data.candidates && data.candidates[0].content.parts[0].text) {
                        return data.candidates[0].content.parts[0].text;
                    } else {
                        throw new Error("Invalid response format from Gemini API");
                    }
                } catch (error) {
                    if (i === retries - 1) {
                        return `오류가 발생했습니다. 나중에 다시 시도해주세요. (${error.message})`;
                    }
                    // Exponential backoff: 1s, 2s, 4s, 8s, 16s
                    await new Promise(resolve => setTimeout(resolve, Math.pow(2, i) * 1000));
                }
            }
        }

        // Simple Markdown parser to convert bold and lists for display
        function parseSimpleMarkdown(text) {
            let html = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>'); // Bold
            html = html.replace(/\*(.*?)\*/g, '<em>$1</em>'); // Italic
            html = html.replace(/\n\n/g, '<br><br>'); // Paragraphs
            html = html.replace(/\n- (.*)/g, '<br>• $1'); // Simple list items
            html = html.replace(/\n\* (.*)/g, '<br>• $1'); // Simple list items
            return html;
        }

